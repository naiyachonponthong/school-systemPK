# Production Environment for HostAtom
NODE_ENV=production
HOSTATOM_PORT=3000

# Database - ใช้ HostAtom Database credentials
DB_HOST=localhost
DB_PORT=3306
DB_NAME=school_personnel
DB_USER=hostatom_db_user
DB_PASSWORD=your_hostatom_db_password

# JWT - ใช้ค่าที่ปลอดภัย
JWT_SECRET=your-super-secure-jwt-secret-key-for-production
JWT_EXPIRES_IN=24h

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
