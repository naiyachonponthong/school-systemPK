# Production Environment
NODE_ENV=production

# Server
PORT=3000

# Database - แก้ไขตาม host จริง
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pkschool_personnel
DB_USER=root
DB_PASSWORD=your_db_password

# JWT - ใช้ secret key ที่ปลอดภัย
JWT_SECRET=your-super-secure-jwt-secret-key-for-production
JWT_EXPIRES_IN=24h

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
