# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=school_personnel
DB_USER=root
DB_PASSWORD=

# JWT (generate a new secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Session
SESSION_TIMEOUT=86400000

# Base URL (สำหรับ production)
BASE_URL=http://localhost:3000
